NODE_ENV=development
LOG_LEVEL=info
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Docker Compose defaults (service-to-service networking).
# For local non-container runs, switch hosts to localhost.
MONGO_URI=mongodb://mongo:27017/ecommerce
REDIS_URL=redis://redis:6379
REDIS_CONNECT_MAX_RETRIES=10
REDIS_CONNECT_RETRY_DELAY_MS=1000

JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_REFRESH_SECRET_MIN_32_CHARS
JWT_ISSUER=ecommerce-api
JWT_AUDIENCE=ecommerce-clients
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
HIBP_PASSWORD_CHECK_ENABLED=false
HIBP_PASSWORD_CHECK_STRICT=false
HIBP_API_BASE_URL=https://api.pwnedpasswords.com
HIBP_TIMEOUT_MS=3000

PAYWAY_BASE_URL=https://sandbox-payway.example.com
PAYWAY_MERCHANT_ID=change_me_merchant_id
PAYWAY_PUBLIC_KEY=change_me_payway_public_key
PAYWAY_MERCHANT_REFERER=http://localhost
PAYWAY_CUSTOMER_EMAIL_FALLBACK=
PAYWAY_WEBHOOK_SECRET=change_me_payway_webhook_secret
PAYWAY_WEBHOOK_IDEMPOTENCY_TTL_SEC=86400
PAYWAY_RETURN_URL_BASE64=
PAYWAY_CANCEL_URL=
PAYWAY_CONTINUE_SUCCESS_URL=

STRIPE_SECRET_KEY=change_me_stripe_key
STRIPE_WEBHOOK_SECRET=change_me_stripe_webhook
STRIPE_WEBHOOK_IDEMPOTENCY_TTL_SEC=86400

PAYMENT_WEBHOOK_LOG_RETENTION_DAYS=30

ADMIN_EMAIL=
ADMIN_PASSWORD=

ORDER_PAYMENT_TIMEOUT_MINUTES=30

# Initial admin seed credentials (only used by seed script)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
