{
  "openapi": "3.0.3",
  "info": {
    "title": "eCommerce API",
    "version": "1.1.0",
    "description": "Backend API for eCommerce platform (auth, catalog, cart, orders, payments, observability)."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    { "name": "health" },
    { "name": "observability" },
    { "name": "auth" },
    { "name": "catalog" },
    { "name": "cart" },
    { "name": "orders" },
    { "name": "payments" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": { "type": "string", "example": "RESOURCE_NOT_FOUND" },
          "message": { "type": "string", "example": "Product not found" },
          "requestId": { "type": "string", "example": "abc123" },
          "details": { "nullable": true }
        },
        "required": ["success", "error", "message", "requestId"]
      },
      "AuthProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["customer", "admin"] }
        },
        "required": ["id", "name", "email", "role"]
      },
      "AuthTokens": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/AuthProfile" },
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" }
        },
        "required": ["user", "accessToken", "refreshToken", "expiresAt"]
      },
      "RefreshTokens": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" }
        },
        "required": ["accessToken", "refreshToken", "expiresAt"]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 80 },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 10, "maxLength": 100 }
        },
        "required": ["name", "email", "password"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "RefreshRequest": {
        "type": "object",
        "properties": {
          "refreshToken": { "type": "string" }
        },
        "required": ["refreshToken"]
      },
      "Category": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["_id", "name", "slug"]
      },
      "Product": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
          "price": { "type": "number" },
          "currency": { "type": "string", "enum": ["USD", "KHR"] },
          "categoryId": { "type": "string" },
          "stock": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "rating": { "type": "number" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["_id", "title", "description", "price", "currency", "categoryId", "stock"]
      },
      "ProductList": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } },
          "nextCursor": { "type": ["string", "null"] }
        },
        "required": ["items", "nextCursor"]
      },
      "CartItem": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "qty": { "type": "integer", "minimum": 1 },
          "priceSnapshot": { "type": "number", "minimum": 0 }
        },
        "required": ["productId", "qty", "priceSnapshot"]
      },
      "Cart": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "deviceId": { "type": "string" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CartItem" } },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["_id", "userId", "deviceId", "items"]
      },
      "CartAddRequest": {
        "type": "object",
        "properties": {
          "productId": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" },
          "qty": { "type": "integer", "minimum": 1, "maximum": 99 }
        },
        "required": ["productId", "qty"]
      },
      "CartUpdateRequest": {
        "type": "object",
        "properties": {
          "productId": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" },
          "qty": { "type": "integer", "minimum": 1, "maximum": 99 }
        },
        "required": ["productId", "qty"]
      },
      "CartRemoveRequest": {
        "type": "object",
        "properties": {
          "productId": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" }
        },
        "required": ["productId"]
      },
      "Address": {
        "type": "object",
        "properties": {
          "fullName": { "type": "string" },
          "phone": { "type": "string" },
          "line1": { "type": "string" },
          "city": { "type": "string" },
          "province": { "type": "string" },
          "postalCode": { "type": "string" }
        },
        "required": ["fullName", "phone", "line1", "city", "province"]
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "title": { "type": "string" },
          "qty": { "type": "integer" },
          "unitPrice": { "type": "number" },
          "lineTotal": { "type": "number" }
        },
        "required": ["productId", "title", "qty", "unitPrice", "lineTotal"]
      },
      "Order": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "deviceId": { "type": "string" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } },
          "subtotal": { "type": "number" },
          "shippingFee": { "type": "number" },
          "total": { "type": "number" },
          "currency": { "type": "string", "enum": ["USD", "KHR"] },
          "status": { "type": "string", "enum": ["pending_payment", "paid", "processing", "shipped", "delivered", "cancelled"] },
          "address": { "$ref": "#/components/schemas/Address" },
          "paymentProvider": { "type": "string", "enum": ["payway", "stripe"] },
          "paywayTranId": { "type": "string" },
          "paywayApv": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["_id", "userId", "items", "subtotal", "shippingFee", "total", "currency", "status", "address", "paymentProvider"]
      },
      "CreateOrderRequest": {
        "type": "object",
        "properties": {
          "address": { "$ref": "#/components/schemas/Address" },
          "shippingFee": { "type": "number", "minimum": 0 },
          "currency": { "type": "string", "enum": ["USD", "KHR"] },
          "paymentProvider": { "type": "string", "enum": ["payway", "stripe"] },
          "paymentOption": { "type": "string" }
        },
        "required": ["address"]
      },
      "PayWayCreateRequest": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" },
          "paymentOption": { "type": "string", "default": "abapay_deeplink" }
        },
        "required": ["orderId"]
      },
      "StripeCreateIntentRequest": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" }
        },
        "required": ["orderId"]
      },
      "HealthStatus": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "mongo": { "type": "boolean" },
          "redis": { "type": "boolean" }
        },
        "required": ["ok", "mongo", "redis"]
      },
      "SuccessAuthProfile": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/AuthProfile" }
        },
        "required": ["success", "data"]
      },
      "SuccessAuthTokens": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/AuthTokens" }
        },
        "required": ["success", "data"]
      },
      "SuccessRefreshTokens": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/RefreshTokens" }
        },
        "required": ["success", "data"]
      },
      "SuccessBoolean": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "boolean", "example": true }
        },
        "required": ["success", "data"]
      },
      "SuccessCategories": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } }
        },
        "required": ["success", "data"]
      },
      "SuccessProduct": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/Product" }
        },
        "required": ["success", "data"]
      },
      "SuccessProductList": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/ProductList" }
        },
        "required": ["success", "data"]
      },
      "SuccessCart": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/Cart" }
        },
        "required": ["success", "data"]
      },
      "SuccessOrder": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/Order" }
        },
        "required": ["success", "data"]
      },
      "SuccessOrders": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Order" } }
        },
        "required": ["success", "data"]
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Healthy",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" }
              }
            }
          },
          "503": {
            "description": "Unhealthy",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": ["observability"],
        "summary": "Prometheus metrics",
        "responses": {
          "200": {
            "description": "Prometheus text exposition format",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registered",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessAuthProfile" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "409": {
            "description": "Email already exists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Login",
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessAuthTokens" }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "429": {
            "description": "Too many login attempts"
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["auth"],
        "summary": "Refresh tokens",
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefreshRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refreshed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessRefreshTokens" }
              }
            }
          },
          "401": {
            "description": "Refresh invalid",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "Logout",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "responses": {
          "200": {
            "description": "Logged out",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessBoolean" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/catalog/categories": {
      "get": {
        "tags": ["catalog"],
        "summary": "List categories",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessCategories" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["catalog"],
        "summary": "Create category (admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "slug": { "type": "string" }
                },
                "required": ["name", "slug"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": { "$ref": "#/components/schemas/Category" }
                  },
                  "required": ["success", "data"]
                }
              }
            }
          },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/api/catalog/products": {
      "get": {
        "tags": ["catalog"],
        "summary": "List products",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "categoryId", "in": "query", "schema": { "type": "string", "pattern": "^[a-fA-F0-9]{24}$" } },
          { "name": "minPrice", "in": "query", "schema": { "type": "number" } },
          { "name": "maxPrice", "in": "query", "schema": { "type": "number" } },
          { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["new", "price_asc", "price_desc"] } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 50 } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessProductList" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/cart": {
      "get": {
        "tags": ["cart"],
        "summary": "Get cart (creates empty cart when missing)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessCart" }
              }
            }
          }
        }
      }
    },
    "/api/cart/add": {
      "post": {
        "tags": ["cart"],
        "summary": "Add product to cart (creates cart when missing)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CartAddRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessCart" }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/cart/update": {
      "post": {
        "tags": ["cart"],
        "summary": "Update cart item quantity",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CartUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessCart" }
              }
            }
          },
          "404": {
            "description": "CART_NOT_FOUND or ITEM_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/cart/remove": {
      "post": {
        "tags": ["cart"],
        "summary": "Remove product from cart",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CartRemoveRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessCart" }
              }
            }
          },
          "404": {
            "description": "CART_NOT_FOUND or ITEM_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/cart/clear": {
      "post": {
        "tags": ["cart"],
        "summary": "Clear cart",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessCart" }
              }
            }
          },
          "404": {
            "description": "CART_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/orders": {
      "post": {
        "tags": ["orders"],
        "summary": "Create order from cart",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "x-device-id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "minLength": 6, "maxLength": 64 }
          }
        ],
